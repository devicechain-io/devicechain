      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(devicechain_eventprocessing_detect_consumer_pending{namespace=\"$namespace\"})",
          "legendFormat": "__auto"
