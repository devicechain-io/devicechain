{
  "name": "@devicechain/frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @devicechain/console",
    "dev:dash": "npm run dev -w @devicechain/dashboard",
    "build": "npm run build --workspaces --if-present",
    "codegen": "npm run codegen -w @devicechain/console",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
