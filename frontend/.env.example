# Copy to .env.local (gitignored) and adjust.

# Backend the dev proxy forwards GraphQL to. Default targets a single
# user-management service on localhost:8080 (the `/api/<area>` prefix is
# stripped, so it answers the plain /graphql path). Point this at the
# DeviceChain ingress to exercise full multi-service routing — and then switch
# the rewrite in vite.config.ts to strip only `/api`.
VITE_GATEWAY_TARGET=http://localhost:8080
