#
# Copy to terraform.tfvars (gitignored) and adjust. The defaults target a local
# single-node cluster; override credentials and pin chart/image versions for any
# real deploy.

# kubeconfig_path    = "~/.kube/config"
# kubeconfig_context = "kind-devicechain"

# namespace        = "dc-system"
# create_namespace = true

# Pin to a tested chart/image version for reproducible deploys.
# nats_chart_version = "1.2.2"
# timescale_image    = "timescale/timescaledb:2.17.2-pg16"

# Change these for anything beyond local dev (or use a pre-created Secret).
# postgres_password  = "CHANGE-ME"
# timescale_password = "CHANGE-ME"

# Data durability (methodology §11). Empty uses the cluster default StorageClass,
# whose reclaimPolicy is usually Delete — so PVC/PV deletion destroys the data.
# FOR PRODUCTION point these at a StorageClass whose reclaimPolicy is Retain, so
# the underlying volume (and its data) survives PVC/PV deletion and a redeploy
# re-attaches it. (The StatefulSets also Retain PVCs on delete/scale and carry a
# prevent_destroy guard — see README "Data durability".)
# postgres_storage_class  = "retain-ssd"
# timescale_storage_class = "retain-ssd"

# Single-node by default; flip on for the ADR-020 HA topology (when implemented).
# ha = false

# Ingress + TLS. Disable either if the cluster already has it; pin chart versions.
# enable_ingress_nginx       = true
# enable_cert_manager        = true
# ingress_class              = "nginx"
# ingress_nginx_chart_version = "4.11.3"
# cert_manager_chart_version  = "v1.16.2"
