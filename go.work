// Floor at 1.26.5 (ADR-060): the embedded Bento connector library
// (warpstreamlabs/bento v1.19, landed in outbound-connectors in slice C4b) declares
// `go 1.26.5`, which propagates the language version to that module and therefore to
// the workspace. The workspace `go` directive must be >= every module's, so it sits at
// 1.26.5; the toolchain directive keeps CI/local on a matching toolchain.
go 1.26.5

toolchain go1.26.5

use (
	./backend/cli
	./backend/core
	./backend/k8s
	./backend/services/command-delivery
	./backend/services/dashboard-management
	./backend/services/device-management
	./backend/services/device-state
	./backend/services/event-management
	./backend/services/event-processing
	./backend/services/event-sources
	./backend/services/mcp
	./backend/services/notification-management
	./backend/services/outbound-connectors
	./backend/services/user-management
	./backend/sims/dc-simulator
	./backend/tools/migrationdiff
	./deploy
)
