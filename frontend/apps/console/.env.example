# Copy to .env.local (gitignored) and adjust.

# Backend the dev proxy forwards GraphQL to. Default targets a single
# user-management service on localhost:8080 (the `/api/<area>` prefix is
# stripped, so it answers the plain /graphql path). Point this at a real
# DeviceChain instance's ingress to exercise full multi-service routing — and
# then drop the rewrite in vite.config.ts (the ingress speaks the same
# `/api/<area>` contract, so the path passes through unchanged).
VITE_GATEWAY_TARGET=http://localhost:8080
